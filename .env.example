DATABASE_URL=postgresql://cars:cars@localhost:5432/cars
REDIS_URL=redis://localhost:6379/0
TELEGRAM_TOKEN=your_bot_token_here
TARGET_URL=https://www.otomoto.pl/osobowe
SCRAPE_PAGES=5
GROQ_API_KEY=your_groq_api_key_here

# ML microservice — set to http://localhost:8000 for local, auto-set in docker-compose
ML_SERVICE_URL=

# MLflow tracking — set to http://localhost:5000 when running mlflow server locally
MLFLOW_TRACKING_URI=mlruns

# Webhook mode — leave empty to use polling (default)
# Set to your public HTTPS URL to enable webhook mode (e.g. https://yourdomain.com)
WEBHOOK_URL=
WEBHOOK_PORT=8443

# Playwright — set to 1 to use headless browser scraping instead of httpx
USE_PLAYWRIGHT=0
